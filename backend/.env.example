# Copy to .env and adjust if needed. These defaults match docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://citybus:citybus@localhost:5432/citybus

# Path to a GTFS feed: a directory of .txt files or a .zip archive.
GTFS_ZIP_PATH=../database/seed/gtfs

# Realtime simulation
REALTIME_ENABLED=true
REALTIME_TICK_SECONDS=2.0
